# Public site URL — used for canonical URL & OG metadata
NEXT_PUBLIC_SITE_URL=https://pharmroo.com

# Supabase — get from https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co

# service_role key (server-only, NEVER expose to client)
# Used by Server Actions to insert leads bypassing RLS
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Password for /admin/leads (HTTP Basic Auth, server-only)
ADMIN_PASSWORD=change-me

# Optional — email notification on new lead via Resend (https://resend.com).
# Leave RESEND_API_KEY blank to disable.
RESEND_API_KEY=
LEAD_NOTIFICATION_EMAIL=you@example.com
# Sender address. Default works without domain setup but goes to spam more
# easily. After verifying pharmroo.com on Resend, switch to a real address.
LEAD_NOTIFICATION_FROM=Pharmroo <onboarding@resend.dev>
